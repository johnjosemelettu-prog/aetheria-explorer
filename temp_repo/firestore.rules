
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: userProfiles
    // Document ID: {userId}
    // Fields:
    //   - displayName: string (optional, < 50 chars)
    //   - email: string (required, < 100 chars, email format)
    //   - photoURL: string (optional, < 200 chars, uri format)
    //   - role: string (optional, enum: ['user', 'admin'])
    //
    // Collection: supportTickets
    // Document ID: {ticketId}
    // Fields:
    //   - userId: string (required, matches auth.uid)
    //   - subject: string (required, < 100 chars)
    //   - message: string (required, < 1000 chars)
    //
    // ===============================================================

    /**
     * AETHERIA AI SECURITY RULES - GUARDIAN GRID v2.8
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * isAdmin check. 
     * IMPORTANT: We avoid reading from /userProfiles/ here to prevent recursive rule evaluation
     * when a user is accessing their own profile. We rely on the /roles_admin/ collection
     * as the authoritative source for administrative clearance.
     */
    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email == 'johnjosemelettu@gmail.com' && request.auth.token.email_verified == true) ||
        (request.auth.token.email == 'admin@aetheria.ai' && request.auth.token.email_verified == true) ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    function isValidUser(data) {
      return data.keys().hasOnly(['displayName', 'email', 'photoURL', 'role']) &&
             data.email is string && data.email.size() < 100 &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 50)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() < 200)) &&
             (!('role' in data) || (data.role in ['user', 'admin']));
    }

    function isValidTicket(data) {
      return data.keys().hasAll(['userId', 'subject', 'message']) &&
             data.userId == request.auth.uid &&
             data.subject is string && data.subject.size() < 100 &&
             data.message is string && data.message.size() < 1000;
    }

    // --- GLOBAL ADMIN BYPASS ---
    // Grants full access to verified administrative nodes.
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }

    // --- COLLECTION RULES ---

    match /userProfiles/{userId} {
      // Users can always read their own profile. 
      // Admin bypass handles other reads.
      allow get: if isOwner(userId);
      allow list: if false; // Only admins via bypass
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
      allow delete: if false; // Only admins via bypass

      // Sub-collections (itineraries, wallet, etc.)
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }

    match /supportTickets/{ticketId} {
      allow create: if isSignedIn() && isValidTicket(request.resource.data);
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      // Updates and deletes handled by admin bypass
    }

    match /supportCalls/{callId} {
      // Managed by admin bypass
      allow read: if false;
    }

    match /roles_admin/{uid} {
      allow read: if isSignedIn();
      // Write access only via admin bypass
    }

    match /destinations/{destinationId} {
      allow read: if true;
      // Write access only via admin bypass
    }

    match /destinationEvents/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource == null || resource.data.organizerId == request.auth.uid);
    }

    match /globalGifts/{giftId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (resource == null || resource.data.senderId == request.auth.uid || resource.data.recipientEmail == request.auth.token.email);
    }

    match /errorLogs/{logId} {
      allow create: if true;
      // Read access only via admin bypass
    }
  }
}
